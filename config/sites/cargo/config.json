{
  "base_url": "https://ecomm.one-line.com/one-ecom/manage-shipment/cargo-tracking",
  "default_timeout": 15,
  "download_dir": "output/cargo/downloads",
  "log": {
    "retention_days": 30
  },
  "login": {
    "enabled": false,
    "url": "",
    "fields": [
      {
        "by": "css",
        "selector": "",
        "value": ""
      },
      {
        "by": "css",
        "selector": "",
        "value": ""
      }
    ],
    "submit": {
      "by": "xpath",
      "selector": ""
    },
    "wait_success": {
      "type": "",
      "by": "xpath",
      "selector": "",
      "timeout": 20
    }
  },
  "tasks": [
    {
      "name": "cargo-tracking",
      "navigation_steps": [
        {
          "action": "sleep",
          "seconds": 10,
          "comment": "页面加载较慢，先固定等待"
        },
        {
          "action": "click_if_exists",
          "by": "xpath",
          "selector": "//div[contains(@class,'Promotion_content')]//button[normalize-space()='Skip' or contains(@class,'PromotionPopoverContent_skip-btn')]",
          "comment": "如出现新手引导遮罩层，先点Skip关闭",
          "timeout": 5,
          "max_rounds": 4,
          "check_next_on_timeout": true,
          "next_check_timeout": 3
        },
        {
          "action": "click",
          "by": "xpath",
          "selector": "(//div[contains(@class,'Select_select-container')])[1]",
          "timeout": 15
        },
        {
          "action": "sleep",
          "seconds": 4,
          "comment": "等待下拉选项浮层渲染"
        },
        {
          "action": "click_if_exists",
          "by": "xpath",
          "selector": "//li[@role='option' and normalize-space()='All'] | //li[@data-testid='tnt-search-multiple-item' and normalize-space()='All'] | //div[@role='option' and normalize-space()='All'] | //button[normalize-space()='All']",
          "timeout": 20,
          "comment": "下拉选项可能延迟出现，轮询点击All"
        },
        {
          "action": "type",
          "by": "css",
          "selector": "input[data-testid='tnt-search-multiple-input']",
          "value": "{{ContainerNo}}",
          "timeout": 20,
          "clear_first": true
        },
        {
          "action": "click",
          "by": "css",
          "selector": "button[data-testid='tnt-search-multiple-button']",
          "timeout": 15
        }
      ],
      "scrape": {
        "list_by": "css",
        "list_selector": "#event-table-container-id table.EventTable_table-container__Qioyi tr.EventTable_table-row__yVKnA",
        "allow_empty": true,
        "fields": [
          {
            "name": " Place",
            "by": "css",
            "selector": "td:nth-child(1) .EventTable_country-name__fax8l",
            "attr": "text"
          },
          {
            "name": "Event",
            "by": "css",
            "selector": "td:nth-child(2) .EventTable_event-name-vessel-group__sDbkT > div:first-child",
            "attr": "text"
          },
          {
            "name": "EventDetail",
            "by": "css",
            "selector": "td:nth-child(2) .EventTable_event-name-vessel-group__sDbkT > div:nth-child(2)",
            "attr": "text"
          },
          {
            "name": "DateTime",
            "by": "css",
            "selector": "td:nth-child(2) .EventDate_event-date-container__dLSip",
            "attr": "text"
          }
        ],
        "max_pages": 5,
        "next_page": {
          "by": "css",
          "selector": ".pagination .next",
          "after_click_sleep": 1.5,
          "timeout": 10
        }
      },
      "output": {
        "format": "json",
        "path": "output/cargo/cargo_tracking.json"
      }
    }
  ]
}
