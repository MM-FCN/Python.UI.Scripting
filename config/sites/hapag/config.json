{
  "_descriptions": {
    "browser": "建议使用 edge；接管模式仅对 edge 生效。",
    "browser_startup.mode": "浏览器启动策略：system=系统直接由 Selenium 启动；batch_attach=先执行批处理启动浏览器再接管。",
    "browser_startup.batch_file": "batch_attach 模式下要执行的批处理文件路径（可相对项目根目录）。",
    "browser_startup.args": "批处理启动参数数组（可选）。",
    "browser_startup.wait_seconds": "执行批处理后等待秒数，给浏览器预热与端口启动时间。",
    "browser_startup.run_once": "true=站点在本次 watcher 生命周期中只启动一次批处理。",
    "startup_navigate": "true=启动后先打开 base_url；false=接管现有浏览器时不强制跳转。",
    "keep_browser_open": "任务结束后是否保持浏览器打开（接管场景建议 true）。",
    "edge.attach_existing": "true=接管已手动打开的 Edge；false=由脚本新开浏览器。",
    "edge.debugger_address": "Edge 远程调试地址，默认 127.0.0.1:9222。"
  },
  "browser": "edge",
  "base_url": "https://www.hapag-lloyd.com/en/online-business/track/track-by-container-solution.html",
  "startup_navigate": true,
  "keep_browser_open": false,
  "edge": {
    "stealth_mode": true,
    "accept_language": "en-US,en;q=0.9",
    "user_data_dir": "",
    "attach_existing": false,
    "debugger_address": ""
  },
  "browser_startup": {
    "mode": "system",
    "batch_file": "run_edge_hapag_9222.bat",
    "args": [],
    "wait_seconds": 3,
    "run_once": true
  },
  "default_timeout": 15,
  "download_dir": "output/hapag/downloads",
  "flaresolverr": {
    "enabled": true,
    "endpoint": "http://localhost:8191/v1",
    "cmd": "request.get",
    "session_id": "hapag-session",
    "session_ttl_minutes": 15,
    "warmup_urls": [
      "https://www.hapag-lloyd.com/en/home.html"
    ],
    "url": "https://www.hapag-lloyd.com/en/online-business/track/track-by-container-solution.html",
    "max_timeout": 60000,
    "request_timeout": 75,
    "cookie_file": "output/hapag/hapag_flaresolverr_cookies.json"
  },
  "fallback": {
    "no_data": {
      "require_any_fields": [
        "Status",
        "Date"
      ],
      "text_contains": [
        "container for given container number not found",
        "no result",
        "not found"
      ]
    }
  },
  "log": {
    "retention_days": 30
  },
  "login": {
    "enabled": false,
    "url": "",
    "fields": [
      {
        "by": "css",
        "selector": "",
        "value": ""
      },
      {
        "by": "css",
        "selector": "",
        "value": ""
      }
    ],
    "submit": {
      "by": "xpath",
      "selector": ""
    },
    "captcha": {
      "type": "checkbox",
      "auto_check_during_steps": true,
      "iframe_selector": "iframe[src*='challenge-platform'], iframe[title*='challenge'], iframe[src*='turnstile'], iframe[id*='cf-chl-widget'], iframe[name*='cf-chl-widget']",
      "popup_selector": "#content, #BbLB6, #TQpKs1, .hal-container-header, .cb-c",
      "checkbox_selector": "#content input[type='checkbox'], #content label.cb-lb, #content .cb-i, #content span.cb-lb-t, #BbLB6 input[type='checkbox'], #BbLB6 label, #BbLB6 [role='checkbox']",
      "success_selector": "#success[style*='display: flex'], #success-text, #success-i, #TQpKs1[style*='display: block']",
      "checkbox_retries": 3,
      "checkbox_monitor_seconds": 12,
      "checkbox_retry_interval_seconds": 0.8,
      "managed_wait_seconds": 20,
      "managed_poll_interval_seconds": 0.8,
      "managed_refresh_retries": 2,
      "managed_verify_xpaths": [
        "//span[contains(normalize-space(), 'Verify you are human')]/ancestor::label",
        "//label[.//span[contains(normalize-space(), 'Verify you are human')]]",
        "//div[@id='content']//label[contains(@class,'cb-lb')]",
        "//div[@id='content']//input[@type='checkbox']",
        "//input[@type='checkbox' or @role='checkbox']"
      ],
      "debug": {
        "enabled": true,
        "dir": "output/challenge-debug"
      }
    },
    "wait_success": {
      "type": "",
      "by": "xpath",
      "selector": "",
      "timeout": 20
    }
  },
  "tasks": [
    {
      "name": "hapag-tracking",
      "navigation_steps": [
        {
          "action": "sleep",
          "seconds": 10,
          "comment": "页面加载较慢，先固定等待"
        },
        {
          "action": "click_if_exists",
          "by": "css",
          "selector": "#accept-recommended-btn-handler",
          "timeout": 6,
          "comment": "若出现Cookie弹窗，点击Select All"
        },
        {
          "action": "click_if_exists",
          "by": "xpath",
          "selector": "//span[normalize-space()='Verify you are human']/ancestor::label | //div[@id='content']//label[contains(@class,'cb-lb')] | //div[@id='content']//input[@type='checkbox']",
          "timeout": 8,
          "comment": "Cloudflare 人机校验出现时勾选复选框，未出现则跳过"
        },
        {
          "action": "sleep",
          "seconds": 2,
          "comment": "勾选后短暂等待验证状态更新"
        },
        {
          "action": "type",
          "by": "xpath",
          "selector": "//input[@id='tracing_by_container_f:hl12']",
          "value": "{{ContainerNo}}",
          "timeout": 20,
          "clear_first": true,
          "comment": "输入ContainerNo"
        },
        {
          "action": "click",
          "by": "xpath",
          "selector": "//button[@id='tracing_by_container_f:hl25']",
          "timeout": 15
        }
      ],
      "scrape": {
        "list_by": "css",
        "list_selector": "#tracing_by_container_f\\:hl66 > tbody > tr",
        "allow_empty": true,
        "no_data_selectors": [
          "span.error[id='tracing_by_container_f:hl11']",
          "#tracing_by_container_f\\:hl11.error",
          "td span.error[releasemessageurl*='track-by-container-solution']"
        ],
        "fields": [
          {
            "name": "Status",
            "by": "css",
            "selector": "td:nth-child(1) span.nonEditableContent",
            "attr": "text"
          },
          {
            "name": "Place",
            "by": "css",
            "selector": "td:nth-child(2) span.nonEditableContent",
            "attr": "text"
          },
          {
            "name": "Date",
            "by": "css",
            "selector": "td:nth-child(3) span.nonEditableContent",
            "attr": "text"
          },
          {
            "name": "Time",
            "by": "css",
            "selector": "td:nth-child(4) span.nonEditableContent",
            "attr": "text"
          },
          {
            "name": "Transport",
            "by": "css",
            "selector": "td:nth-child(5) span.nonEditableContent",
            "attr": "text"
          },
          {
            "name": "VoyageNo",
            "by": "css",
            "selector": "td:nth-child(6) span.nonEditableContent",
            "attr": "text"
          }
        ],
        "max_pages": 5,
        "next_page": {
          "by": "css",
          "selector": ".pagination .next",
          "after_click_sleep": 1.5,
          "timeout": 10
        }
      },
      "output": {
        "format": "json",
        "path": "output/hapag/hapag_tracking.json"
      }
    }
  ]
}
