{
  "browser": "edge",
  "base_url": "https://www.msccargo.cn/en/track-a-shipment",
  "edge": {
    "stealth_mode": true,
    "accept_language": "en-US,en;q=0.9",
      "user_data_dir": "C:/MyEdgeData",
      "use_user_profile": true,
      "attach_existing": false,
    "debugger_address": "127.0.0.1:9222"
  },
  "default_timeout": 15,
  "download_dir": "output/msc/downloads",
  "fallback": {
    "no_data": {
      "require_any_fields": [
        "Date",
        "Description"
      ],
      "text_contains": [
        "no results found for this bill of lading number",
        "please recheck that the number is complete and correct and in the b/l format",
        "no data",
        "no result",
        "not found"
      ]
    }
  },
  "log": {
    "retention_days": 30
  },
  "login": {
    "enabled": false,
    "url": "",
    "fields": [
      {
        "by": "css",
        "selector": "",
        "value": ""
      },
      {
        "by": "css",
        "selector": "",
        "value": ""
      }
    ],
    "submit": {
      "by": "xpath",
      "selector": ""
    },
    "wait_success": {
      "type": "",
      "by": "xpath",
      "selector": "",
      "timeout": 20
    }
  },
  "tasks": [
    {
      "name": "msc-tracking",
      "navigation_steps": [
        {
          "action": "sleep",
          "seconds": 10,
          "comment": "页面加载较慢，先固定等待"
        },
        {
          "action": "click_if_exists",
          "by": "css",
          "selector": "#onetrust-accept-btn-handler",
          "comment": "如存在Cookie弹窗则点击Accept All",
          "timeout": 8
        },
        {
          "action": "wait_present",
          "by": "css",
          "selector": "input.msc-quicktool__search[x-model='trackingBox.trackingNumber'][data-type='search'], input.msc-quick-access-box__search[x-model='trackingBox.trackingNumber'][data-type='search'], input#trackingNumber[data-type='search'], input[x-model='trackingNumber'][data-type='search']",
          "timeout": 35,
          "comment": "等待MSC搜索输入框在 DOM 中出现（兼容不同页面模板，包括 id/trackingNumber 或 x-model=trackingNumber）"
        },
        {
          "action": "type",
          "by": "css",
          "selector": "input.msc-quicktool__search[x-model='trackingBox.trackingNumber'][data-type='search'], input.msc-quick-access-box__search[x-model='trackingBox.trackingNumber'][data-type='search'], input#trackingNumber[data-type='search'], input[x-model='trackingNumber'][data-type='search']",
          "value": "{{ContainerNo}}",
          "timeout": 35,
          "clear_first": true,
          "comment": "输入提单/箱号到MSC搜索框"
        },
        {
          "action": "click_if_exists",
          "by": "css",
          "selector": "button.msc-cta-icon-simple.msc-search-autocomplete__search, button.msc-search-autocomplete__search",
          "timeout": 12,
          "comment": "优先点击搜索按钮触发tracking跳转"
        },
        {
          "action": "press_enter_if_exists",
          "by": "css",
          "selector": "input.msc-quicktool__search[x-model='trackingBox.trackingNumber'][data-type='search'], input.msc-quick-access-box__search[x-model='trackingBox.trackingNumber'][data-type='search'], input#trackingNumber[data-type='search'], input[x-model='trackingNumber'][data-type='search']",
          "timeout": 12,
          "comment": "若按钮未触发则在输入框按回车兜底提交"
        }
        ,
        {
          "action": "wait",
          "by": "css",
          "selector": ".msc-flow-tracking__steps .msc-flow-tracking__port .msc-flow-tracking__step, .msc-search-autocomplete__no-results, .msc-search-autocomplete__empty",
          "timeout": 35,
          "comment": "等待结果列表出现或无结果提示，避免直接超时报错"
        }
      ],
      "scrape": {
        "list_by": "css",
        "fast_extract_enabled": false,
        "fast_extract_threshold": 8,
        "list_selector": ".msc-flow-tracking__steps .msc-flow-tracking__port .msc-flow-tracking__step",
        "timeout": 35,
        "allow_empty": true,
        "no_data_selectors": [
          ".msc-search-autocomplete__no-results",
          ".msc-search-autocomplete__empty",
          ".msc-flow-tracking__tracking:empty"
        ],
        "fields": [
          {
            "name": "Date",
            "by": "css",
            "selector": ".msc-flow-tracking__cell--two .data-value",
            "attr": "text"
          },
          {
            "name": "Location",
            "by": "css",
            "selector": ".msc-flow-tracking__cell--three .data-value",
            "attr": "text"
          },
          {
            "name": "Description",
            "by": "css",
            "selector": ".msc-flow-tracking__cell--four .data-value",
            "attr": "text"
          },
          {
            "name": "Detail",
            "by": "css",
            "selector": ".msc-flow-tracking__cell--five .data-value",
            "attr": "text"
          },
          {
            "name": "EquipmentHandling",
            "by": "css",
            "selector": ".msc-flow-tracking__cell--six .data-value",
            "attr": "text"
          }
        ],
        "max_pages": 1
      },
      "output": {
        "format": "json",
        "path": "output/msc/msc_tracking.json"
      }
    }
  ]
}
