{
  "base_url": "https://sso.byd.com/",
  "default_timeout": 15,
  "download_dir": "output/site2/downloads",
  "log": {
    "retention_days": 30
  },
  "login": {
    "enabled": true,
    "url": "https://sso.byd.com/login/#/external?lck=contextInformation_b93ce28f325d4c9e9a41b02d07028f4c&theme=aee68d1a867a439b8710d8118e69734b",
    "cookie_file": "output/site2/cookies.json",
    "fields": [
      {
        "by": "css",
        "selector": "input[placeholder='请输入账号']",
        "value": "111"
      },
      {
        "by": "css",
        "selector": "input[placeholder^='请输入密码']",
        "value": "1111"
      }
    ],
    "submit": {
      "by": "css",
      "selector": "button.login-submit"
    },
    "captcha": {
      "type": "slider",
      "popup_selector": ".sliderIcon",
      "popup_timeout": 20,
      "canvas_selector": ".canvasArea canvas",
      "piece_img_selector": ".canvasArea .block img, .block img",
      "bg_selector": ".sliderBg, .captcha-bg",
      "piece_selector": ".sliderBlock, .captcha-block",
      "slider_selector": ".sliderIcon",
      "wait_selector": "",
      "fail_selector": ".login-error-msg",
      "fail_text": "图形验证不通过",
      "reopen_by": "css",
      "reopen_selector": "button.login-submit",
      "refresh_selector": ".slider-refresh, .captcha-refresh, .iconfont.icon-shuaxin",
      "timeout": 15
    },
    "wait_success": {
      "type": "url_not_contains",
      "value": "/login",
      "timeout": 30
    }
  },
  "tasks": [
    {
      "name": "reports_main",
      "navigation_steps": [
        {
          "action": "click",
          "by": "css",
          "selector": "a.nav-reports"
        },
        {
          "action": "wait",
          "by": "css",
          "selector": ".data-table",
          "timeout": 15
        }
      ],
      "scrape": {
        "list_by": "css",
        "list_selector": ".data-table tbody tr",
        "fields": [
          {
            "name": "编号",
            "by": "css",
            "selector": "td:nth-child(1)",
            "attr": "text"
          },
          {
            "name": "名称",
            "by": "css",
            "selector": "td:nth-child(2)",
            "attr": "text"
          }
        ],
        "max_pages": 5,
        "next_page": {
          "by": "css",
          "selector": ".pagination .next",
          "after_click_sleep": 1.5,
          "timeout": 10
        }
      },
      "output": {
        "format": "json",
        "path": "output/site2/result_reports_main.json"
      }
    }
  ]
}
