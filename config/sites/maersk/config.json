{
  "browser": "edge",
  "base_url": "https://www.maersk.com/tracking/",
  "edge": {
    "stealth_mode": true,
    "accept_language": "en-US,en;q=0.9",
    "user_data_dir": "",
    "attach_existing": false,
    "debugger_address": ""
  },
  "default_timeout": 15,
  "download_dir": "output/maersk/downloads",
  "fallback": {
    "no_data": {
      "require_any_fields": [
        "Event",
        "DateTime"
      ],
      "text_contains": [
        "未找到结果",
        "no data",
        "no result",
        "not found"
      ]
    }
  },
  "log": {
    "retention_days": 30
  },
  "login": {
    "enabled": false,
    "url": "",
    "fields": [
      {
        "by": "css",
        "selector": "",
        "value": ""
      },
      {
        "by": "css",
        "selector": "",
        "value": ""
      }
    ],
    "submit": {
      "by": "xpath",
      "selector": ""
    },
    "wait_success": {
      "type": "",
      "by": "xpath",
      "selector": "",
      "timeout": 20
    }
  },
  "tasks": [
    {
      "name": "maersk-tracking",
      "navigation_steps": [
        {
          "action": "sleep",
          "seconds": 5,
          "comment": "页面加载较慢，先固定等待"
        },
        {
          "action": "click_if_exists",
          "by": "css",
          "selector": "button[data-test='coi-allow-all-button']",
          "timeout": 8,
          "comment": "如出现Cookie弹窗则点击允许全部"
        },
        {
          "action": "type_shadow",
          "host_selector": "mc-input[data-test='track-input']",
          "selector": "input#mc-input-track-input",
          "value": "{{ContainerNo}}",
          "timeout": 20,
          "clear_first": true,
          "comment": "输入提单号或集装箱编号"
        },
        {
          "action": "click_shadow",
          "host_selector": "mc-button[data-test='track-button']",
          "selector": "button[aria-label='Track'], button[aria-label='跟踪']",
          "timeout": 15,
          "comment": "点击跟踪按钮发起查询（兼容英文Track与中文跟踪）"
        }
      ],
      "scrape": {
      "list_by": "css",
      "fast_extract_enabled": false,
      "fast_extract_threshold": 8,
        "list_selector": "div[data-test='transport-plan'] ul[data-test='transport-plan-list'] > li.transport-plan__list__item",
        "allow_empty": true,
        "no_data_selectors": [
          "[data-testid='tnt-no-data-found-title']",
          "[data-testid='tnt-no-data-found-subtitle']",
          "[data-testid='tnt-no-data-found-icon']",
          ".Empty_content__0SI15"
        ],
        "fields": [
          {
            "name": "Status",
            "by": "xpath",
            "selector": ".",
            "attr": "data-test"
          },
          {
            "name": "Place",
            "by": "css",
            "selector": "div.location[data-test='location-name']",
            "attr": "text"
          },
          {
            "name": "Event",
            "by": "css",
            "selector": "div.milestone[data-test='milestone'] > span:first-child",
            "attr": "text"
          },
          {
            "name": "DateTime",
            "by": "css",
            "selector": "div.milestone[data-test='milestone'] span[data-test='milestone-date']",
            "attr": "text"
          },
          {
            "name": "Icon",
            "by": "css",
            "selector": "mc-icon[data-test='icon']",
            "attr": "icon"
          }
        ],
        "max_pages": 5,
        "next_page": {
          "by": "css",
          "selector": ".pagination .next",
          "after_click_sleep": 1.5,
          "timeout": 10
        }
      },
      "output": {
        "format": "json",
        "path": "output/maersk/maersk_tracking.json"
      }
    }
  ]
}
