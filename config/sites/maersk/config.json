{
  "browser": "edge",
  "base_url": "https://www.maersk.com/tracking/",
  "default_timeout": 15,
  "download_dir": "output/maersk/downloads",
  "fallback": {
    "no_data": {
      "require_any_fields": [
        "Event",
        "DateTime"
      ],
      "text_contains": [
        "未找到结果",
        "no data",
        "no result",
        "not found"
      ]
    }
  },
  "log": {
    "retention_days": 30
  },
  "login": {
    "enabled": false,
    "url": "",
    "fields": [
      {
        "by": "css",
        "selector": "",
        "value": ""
      },
      {
        "by": "css",
        "selector": "",
        "value": ""
      }
    ],
    "submit": {
      "by": "xpath",
      "selector": ""
    },
    "wait_success": {
      "type": "",
      "by": "xpath",
      "selector": "",
      "timeout": 20
    }
  },
  "tasks": [
    {
      "name": "maersk-tracking",
      "navigation_steps": [
        {
          "action": "sleep",
          "seconds": 5,
          "comment": "页面加载较慢，先固定等待"
        },
        {
          "action": "click_if_exists",
          "by": "css",
          "selector": "button[data-test='coi-allow-all-button']",
          "timeout": 8,
          "comment": "如出现Cookie弹窗则点击允许全部"
        },
        {
          "action": "type_shadow",
          "host_selector": "mc-input[data-test='track-input']",
          "selector": "input#mc-input-track-input",
          "value": "{{ContainerNo}}",
          "timeout": 20,
          "clear_first": true,
          "comment": "输入提单号或集装箱编号"
        },
        {
          "action": "click_shadow",
          "host_selector": "mc-button[data-test='track-button']",
          "selector": "button[aria-label='跟踪']",
          "timeout": 15,
          "comment": "点击跟踪按钮发起查询"
        }
      ],
      "scrape": {
        "list_by": "css",
        "list_selector": "#event-table-container-id table.EventTable_table-container__Qioyi tr.EventTable_table-row__yVKnA",
        "allow_empty": true,
        "no_data_selectors": [
          "[data-testid='tnt-no-data-found-title']",
          "[data-testid='tnt-no-data-found-subtitle']",
          "[data-testid='tnt-no-data-found-icon']",
          ".Empty_content__0SI15"
        ],
        "fields": [
          {
            "name": " Place",
            "by": "css",
            "selector": "td:nth-child(1) .EventTable_country-name__fax8l",
            "attr": "text"
          },
          {
            "name": "Event",
            "by": "css",
            "selector": "td:nth-child(2) .EventTable_event-name-vessel-group__sDbkT > div:first-child",
            "attr": "text"
          },
          {
            "name": "EventDetail",
            "by": "css",
            "selector": "td:nth-child(2) .EventTable_event-name-vessel-group__sDbkT > div:nth-child(2)",
            "attr": "text"
          },
          {
            "name": "DateTime",
            "by": "css",
            "selector": "td:nth-child(2) .EventDate_event-date-container__dLSip",
            "attr": "text"
          }
        ],
        "max_pages": 5,
        "next_page": {
          "by": "css",
          "selector": ".pagination .next",
          "after_click_sleep": 1.5,
          "timeout": 10
        }
      },
      "output": {
        "format": "json",
        "path": "output/maersk/maersk_tracking.json"
      }
    }
  ]
}
