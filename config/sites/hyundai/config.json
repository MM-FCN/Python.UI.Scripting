{
  "browser": "edge",
  "base_url": "https://www.hmm21.com/e-service/general/trackNTrace/TrackNTrace.do",
  "edge": {
    "stealth_mode": true,
    "accept_language": "en-US,en;q=0.9",
    "user_data_dir": "",
    "attach_existing": false,
    "debugger_address": ""
  },
  "default_timeout": 15,
  "download_dir": "output/hyundai/downloads",
  "merged_output": {
    "enabled": true,
    "path": "output/hyundai/hyundai_merged.json",
    "append_timestamp": true,
    "as_array": true,
    "global_identifier_keys": [
      "ContainerNo"
    ]
  },
  "fallback": {
    "no_data": {
      "require_any_fields": [
        "Origin",
        "Destination",
        "VesselVoyage"
      ],
      "text_contains": [
        "container number is invalid. please try it again with correct number",
        "invalid value",
        "no data",
        "no result",
        "not found"
      ]
    }
  },
  "log": {
    "retention_days": 30
  },
  "login": {
    "enabled": false,
    "url": "",
    "fields": [
      {
        "by": "css",
        "selector": "",
        "value": ""
      },
      {
        "by": "css",
        "selector": "",
        "value": ""
      }
    ],
    "submit": {
      "by": "xpath",
      "selector": ""
    },
    "wait_success": {
      "type": "",
      "by": "xpath",
      "selector": "",
      "timeout": 20
    }
  },
  "tasks": [
    {
      "name": "hyundai-tracking",
      "merge_key": "Tracking",
      "navigation_steps": [
        {
          "action": "sleep",
          "seconds": 10,
          "comment": "页面加载较慢，先固定等待"
        },
        {
          "action": "type",
          "by": "css",
          "selector": "input[name='srchCntrNo1']",
          "value": "{{ContainerNo}}",
          "timeout": 20,
          "clear_first": true,
          "comment": "输入箱号到 Hyundai 查询框"
        },
        {
          "action": "click",
          "by": "css",
          "selector": "button.btn.line.medium[onclick='search()']",
          "timeout": 15,
          "comment": "点击Retrieve按钮执行查询"
        }
      ],
      "scrape": {
        "list_by": "xpath",
        "list_selector": "//div[contains(@class,'table-wrap')][.//thead//*[contains(normalize-space(),'Origin')] and .//thead//*[contains(normalize-space(),'Destination')]]//tbody/tr",
        "timeout": 35,
        "allow_empty": true,
        "no_data_selectors": [
          ".input .icon.red.emphasis",
          ".icon.red.emphasis"
        ],
        "fields": [
          {
            "name": "RowType",
            "by": "css",
            "selector": "th .text",
            "attr": "text"
          },
          {
            "name": "Origin",
            "by": "css",
            "selector": "td:nth-child(2) .text",
            "attr": "text"
          },
          {
            "name": "LoadingPort",
            "by": "css",
            "selector": "td:nth-child(3) .text",
            "attr": "text"
          },
          {
            "name": "TSPort",
            "by": "css",
            "selector": "td:nth-child(4) .text",
            "attr": "text"
          },
          {
            "name": "DischargingPort",
            "by": "css",
            "selector": "td:nth-child(5) .text",
            "attr": "text"
          },
          {
            "name": "Destination",
            "by": "css",
            "selector": "td:nth-child(6) .text",
            "attr": "text"
          }
        ],
        "max_pages": 1
      },
      "output": {
        "format": "json",
        "path": "output/hyundai/hyundai_tracking.json"
      }
    },
    {
      "name": "hyundai-vessel-voyage",
      "merge_key": "VesselVoyage",
      "navigation_steps": [],
      "scrape": {
        "list_by": "xpath",
        "list_selector": "//div[contains(@class,'table-wrap')][.//thead//*[contains(normalize-space(),'Vessel') and contains(normalize-space(),'Voyage')] and .//thead//*[contains(normalize-space(),'Arrival')]]//tbody/tr",
        "timeout": 35,
        "allow_empty": true,
        "no_data_selectors": [
          ".input .icon.red.emphasis",
          ".icon.red.emphasis"
        ],
        "fields": [
          {
            "name": "VesselVoyage",
            "by": "css",
            "selector": "td:nth-child(1) .text",
            "attr": "text"
          }
        ],
        "max_pages": 1
      },
      "output": {
        "format": "json",
        "path": "output/hyundai/hyundai_vessel_voyage.json"
      }
    }
  ]
}
